# Copy this file to .env and fill in available keys.
# Never commit real keys.

BLS_API_KEY=
# Optional fallback keys, separated by commas/spaces. The provider tries BLS_API_KEY first.
BLS_API_KEYS=
FRED_API_KEY=
BEA_API_KEY=
CENSUS_API_KEY=
DOL_API_KEY=

# Optional paths
LABOR_DASHBOARD_CATALOG_DIR=catalog
LABOR_DASHBOARD_RAW_DIR=data/raw
LABOR_DASHBOARD_PROCESSED_DIR=data/processed
LABOR_DASHBOARD_STATIC_DIR=site/public/data
LABOR_DASHBOARD_SEARCH_DIR=site/public/search
