# Secrets and local configuration
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Internal-only project memory / handoff material
/do/

# Planning artifacts (orchestration framework — never tracked)
*.plan.md
plan.md
plans/

# Project-local working state / generated outputs
/var/
/outputs/
/tmp/
/.jobgauge/
/exports/agent/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# Data cache and large local data
/data/raw/
/data/cache/
/data/processed/
/data/warehouse/
*.duckdb
*.sqlite
*.parquet.tmp

# OS/editor
.DS_Store
.idea/
.vscode/

# Node/frontend build outputs (frontend is deferred)
node_modules/
dist/
build/

# Keep static publish outputs trackable by default
!site/public/data/
!site/public/search/
